# Backend Configuration Example
# Copy to appsettings.Development.json for local development

{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.EntityFrameworkCore.Database.Command": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "User ID=postgres;Password=postgres;Host=localhost;Port=5432;Database=capstone_db;"
  },
  "AllowedHosts": "*"
}
